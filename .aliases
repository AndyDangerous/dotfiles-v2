
# ALIASES
# Path
alias     ..="cd .."
alias    ...="cd ../.."
alias   ....="cd ../../.."
alias  .....="cd ../../../.."
alias ......="cd ../../../../.."

# Shell
alias la="ls -alFGgohq"
# fancy ls command
  # -l  long format
  # -F  / after dirs, * after exe, @ after symlink
  # -G  colorize
  # -g suppress owner
  # -o suppress group
  # -h humanize sizes
  # -q print nongraphic chars as question marks
alias ll="ls -lFGgohq"

# Tmux
alias tml='tmux ls'
alias tmn='tmux new -s'
alias tma='tmux attach -t'
alias tmk='tmux kill-session -t'

# Git
alias gap='git add -p'
alias ga='git add'
alias gnap='git add -N --ignore-removal . && gap'
  alias glg='git log --graph --oneline --decorate --color --all'
alias gb='git branch'
alias gc='git commit -v'
alias gd='git diff --color-words'
alias glod='git log --graph --pretty="%Cgreen%h%Creset%Cblue%d%Creset %Cred%an%Creset: %s"'
  alias glod='git log --oneline --decorate'
alias gp='git push'
alias gpr='git pull --rebase'
alias gst='git status'
alias gcm="git commit -m"
alias gca="git commit --amend --no-edit"
alias gco="git checkout"
alias glog="git log --pretty=oneline"
alias gh='git config --get remote.origin.url | ruby -ne "puts %{https://github.com/#{\$_.split(/.com[\:\/]/)[-1].gsub(%{.git},%{})}}"| xargs open'
  alias gsm='git switch main && git pull --rebase'
  alias gpm='git switch main && git pull --rebase && git switch - && git rebase origin/main'

# Bash
alias hg="history | grep"

# Ruby
alias be="bundle exec"

# Vim
alias vi="nvim"

# Docker
# alias docker-kill-all="docker kill `docker ps -aq`"
# alias docker-rm-all="docker rm `docker ps -aq`"

# Dirs
alias hbase="cd ~/development/Homebase1/"

# Other Homebase Stuff
alias dbconnect="PGPASSWORD=homebase pgcli -h 127.0.0.1 -U hai -p"
